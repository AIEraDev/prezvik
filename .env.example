# Kyro AI Provider Configuration
# Copy this file to .env and add your API keys

# Default provider (optional - defaults to "openai" if not set)
# Options: openai, anthropic, groq
KYRO_DEFAULT_PROVIDER=openai

# OpenAI (default provider)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Groq (fast, open models)
# GROQ_API_KEY=gsk_...

# Only one API key is required - uncomment and use your preferred provider
