# Kyro AI Provider Configuration
# Copy this file to .env.local and add your API keys

# Groq (primary - speed & balanced tiers)
# Free tier: 1,000 requests/day, 200-350 tokens/sec
GROQ_API_KEY=gsk_...

# Anthropic (optional - quality tier)
# Claude Haiku 4.5 - cheap, reliable for quality tier
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI (not used by default)
# OPENAI_API_KEY=sk-...

# Note: With Groq + Anthropic, strategies map as:
# - speed: Groq (llama-3.3-70b or 8b-instant)
# - balanced: Groq (llama-3.3-70b)
# - quality: Anthropic (claude-haiku-4-5)

# Kyro Pipeline Configuration
# Pipeline rendering mode: 'legacy' (default) or 'layered' (new three-layer architecture)
# KYRO_PIPELINE_MODE=legacy

# Enable/disable performance monitoring (default: true)
# KYRO_ENABLE_PERFORMANCE_MONITORING=true

# Enable/disable caching (default: true)
# KYRO_ENABLE_CACHING=true

# Log level: debug, info, warn, error (default: info)
# KYRO_LOG_LEVEL=info
